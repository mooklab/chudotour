mixin input(placeholder, required)
    fieldset.input
        input(type="text", placeholder=" ", required=(required))
        span= placeholder

mixin checkbox(name, title, ischecked = false)
    label.checkbox
        input(type="checkbox", checked=ischecked)
        span!= title

mixin radio(name, title, checked)
    label.radio
        input(type="radio", name=name, checked=(checked))
        span= title

mixin select(name, placeholder, ...items)
    fieldset(class=name, tabindex="0").select
        div.select_choice
            if placeholder
                input(type="radio", id=name, name=name, checked).placeholder
                span= placeholder
            each item, index in items
                input(type="radio", id=name + "_" + index, name=name, checked=(!placeholder && index === 0))
                span !{item}
            if block
                block
            else
                img(src="images/select_arrow.svg", alt="").arrow
        div.select_dropdown
            div.select_dropdown_overflow
                div.select_dropdown_content
                    each item, index in items
                        label(for=name + "_" + index) !{item}

mixin datepicker(title)
    fieldset.datepicker
        input(type="date", required)
        span= title

mixin tourist_select
    fieldset(tabindex="0").tourists
        div.select
            span Туристы
            img(src="images/select_arrow.svg")
        div.select_popup
            div.select_overflow
                div.select_content
                    div.parents
                        div.text
                            strong Взрослые
                            span Старше 14 лет
                        div.quantity
                            div.minus
                                include ../../../images/quantity_minus.svg
                            input(type="number", min="1", max="9")
                            div.plus
                                include ../../../images/quantity_plus.svg
                    div.childs
                        div.text
                            strong Дети
                            span От 1 до 14 лет
                        div.quantity
                            div.minus
                                include ../../../images/quantity_minus.svg
                            input(type="number", min="0", max="9")
                            div.plus
                                include ../../../images/quantity_plus.svg

mixin tour_card(image, title, destination, price)
