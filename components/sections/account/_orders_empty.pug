include ../../common/pug/_mixins.pug

section.orders_empty
    div.container

        +account_sidemenu('images/6.webp', 'Константинопольский Константин ', 'konstatin.konstantin123@gmail.com', '1', 'Мои данные', 'Бронирования', 'Документы', 'Выйти')

        div.account_page
            h1 Бронирования

            div.filter
                span.tag.active Все (100)
                span.tag Текущие (100)
                span.tag Прошедшие (100)
                +select('account_tour', 'Сортировка', 'Все', 'Не подтверждено', 'Ожидает обработки', 'Подтверждено, частично оплачено', 'Подтверждено, не оплачено', 'Подтверждено, оплачено', 'Завершено, не оплачено', 'Завершено')

            div.empty
                img(src="images/empty_orders.svg")
                h2 Пока нет активных заказов
                span На этой странице будут отображаться ваши заказы