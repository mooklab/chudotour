include ../common/pug/_mixins.pug

section.reviews
    div.container

        div.yandex
            div.subscribers
                img(src="images/reviews_vkontakte.svg", alt="Вконтакте")
                span #[b 13 000+ ] подписчиков
            div.rating
                img(src="images/reviews_yandex.svg", alt="Яндекс").logotype
                div.overall
                    span.digit 5.0
                    div.reviews_count
                        div.stars
                            img(src="images/review_star.svg")
